<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name="MainApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        tools:targetApi="33">

        <service
            android:name="OpenMoaIME"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">

            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>

            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />

        </service>

        <activity
            android:name="pe.aioo.openmoa.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.OpenMoa.Settings" />

        <activity
            android:name="pe.aioo.openmoa.settings.ShortcutSettingsActivity"
            android:exported="false"
            android:label="@string/settings_shortcut_title"
            android:theme="@style/Theme.OpenMoa.Settings" />

        <activity
            android:name="pe.aioo.openmoa.settings.PhraseEditActivity"
            android:exported="false"
            android:theme="@style/Theme.OpenMoa.QuickPhraseEdit" />

        <activity
            android:name="pe.aioo.openmoa.settings.GestureAngleActivity"
            android:exported="false"
            android:label="@string/settings_gesture_angle_title"
            android:theme="@style/Theme.OpenMoa.Settings"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name="pe.aioo.openmoa.settings.HotstringListActivity"
            android:exported="false"
            android:label="@string/settings_hotstring_manage_title"
            android:theme="@style/Theme.OpenMoa.Settings" />

        <activity
            android:name="pe.aioo.openmoa.settings.DevToolsActivity"
            android:exported="false"
            android:label="@string/dev_tools_title"
            android:theme="@style/Theme.OpenMoa.Settings" />

        <activity
            android:name="pe.aioo.openmoa.clipboard.ClipboardEditActivity"
            android:exported="false"
            android:label="@string/clipboard_edit_title"
            android:theme="@style/Theme.OpenMoa.Settings" />

    </application>

</manifest>