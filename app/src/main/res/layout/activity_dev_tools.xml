<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/amplitudeStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/hapticLightButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/dev_tools_haptic_test_light" />

        <Button
            android:id="@+id/hapticMediumButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/dev_tools_haptic_test_medium" />

        <Button
            android:id="@+id/hapticStrongButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dev_tools_haptic_test_strong" />

    </LinearLayout>

</ScrollView>
